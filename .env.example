# Optional local secrets — copy to `.env` (gitignored) and load before Codex.
# Not required for `just check` or CI.
#
# See README.md § "Optional: GitHub MCP" and CONTRIBUTING.md (Reviewer + Planner).

# Fine-scoped GitHub PAT (issues/PRs read). Used when `[mcp_servers.github]` is
# configured in `.codex/config.toml`.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional: same PAT class as above, stored as repo secret SCHEDULER_DISPATCH_TOKEN
# (not loaded from .env in CI). Enables pull_request CI/route on scheduler-opened PRs.
# See CONTRIBUTING.md § Scheduled executor.
